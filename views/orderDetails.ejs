<%- include("./partials/header") %>

<div class="min-h-screen bg-pink-100">
    <div class="max-w-7xl mx-auto px-8 py-10">

        <div class="flex justify-between items-center mb-8">

            <div>
                <h1 class="text-4xl font-semibold">Order Details</h1>
                <p class="text-gray-500 mt-2">
                    Order ID : <%= order._id %>
                </p>
            </div>

            <a href="/orders" class="bg-pink-400 hover:bg-pink-500 text-white px-6 py-3 rounded-xl font-semibold transition">
                Back to Orders
            </a>

        </div>

        <div class="flex gap-8">

            <div class="w-[68%] flex flex-col gap-6">

                <div class="bg-white rounded-xl shadow-md p-6">

                    <h2 class="text-2xl font-semibold mb-6">
                        Ordered Items
                    </h2>

                    <% order.items.forEach(function(item){ %>

                        <div class="flex justify-between items-center border-b pb-5 mb-5">

                            <div class="flex items-center gap-5">

                                <div class="w-24 h-24 rounded-lg bg-pink-100 flex justify-center items-center">
                                    <img class="max-h-20" src="data:image/jpeg;base64,<%= item.image.toString('base64') %>">
                                </div>

                                <div>

                                    <h3 class="text-xl font-semibold">
                                        <%= item.name %>
                                    </h3>

                                    <p class="text-gray-500 mt-1">
                                        Quantity : <%= item.quantity %>
                                    </p>

                                    <p class="text-gray-500">
                                        ₹ <%= item.price %> each
                                    </p>

                                </div>

                            </div>

                            <div class="text-right">

                                <p class="text-xl font-semibold">
                                    ₹ <%= (item.price - item.discount) * item.quantity %>
                                </p>

                            </div>

                        </div>

                    <% }) %>

                </div>

            </div>

            <div class="w-[32%] flex flex-col gap-6">

                <div class="bg-white rounded-xl shadow-md p-6">

                    <h2 class="text-2xl font-semibold mb-6">
                        Order Status
                    </h2>

                    <div class="flex justify-between mb-4">
                        <span>Status</span>
                        <span class="text-pink-500 font-semibold">
                            <%= order.orderStatus %>
                        </span>
                    </div>

                    <div class="flex justify-between mb-4">
                        <span>Payment</span>
                        <span>
                            <%= order.paymentMethod %>
                        </span>
                    </div>

                    <div class="flex justify-between">
                        <span>Placed On</span>
                        <span>
                            <%= order.createdAt.toDateString() %>
                        </span>
                    </div>

                </div>

                <div class="bg-white rounded-xl shadow-md p-6">

                    <h2 class="text-2xl font-semibold mb-6">
                        Delivery Address
                    </h2>

                    <p class="whitespace-pre-line"><%= order.deliveryAddress %></p>

                </div>

                <div class="bg-white rounded-xl shadow-md p-6">

                    <h2 class="text-2xl font-semibold mb-6">
                        Payment Summary
                    </h2>

                    <div class="flex justify-between mb-3">
                        <span>Total MRP</span>
                        <span>₹ <%= order.totalMRP %></span>
                    </div>

                    <div class="flex justify-between mb-3">
                        <span>Discount</span>
                        <span>-₹ <%= order.totalDiscount %></span>
                    </div>

                    <div class="flex justify-between mb-3">
                        <span>Platform Fee</span>
                        <span>₹ <%= order.platformFee %></span>
                    </div>

                    <div class="flex justify-between mb-6">
                        <span>Shipping</span>
                        <span class="text-green-600 font-medium">
                            FREE
                        </span>
                    </div>

                    <hr>

                    <div class="flex justify-between text-2xl font-bold mt-6">
                        <span>Total</span>
                        <span class="text-pink-500">
                            ₹ <%= order.totalAmount %>
                        </span>
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<%- include("./partials/footer") %>