<%- include("./partials/header") %>

<div class="min-h-screen bg-pink-100">
    <div class="max-w-7xl mx-auto px-8 py-10">

        <h1 class="text-4xl font-semibold mb-8">My Orders</h1>

        <% if(orders.length === 0) { %>

            <div class="bg-white rounded-xl shadow-md p-16 text-center">

                <i class="ri-shopping-bag-3-line text-7xl text-pink-500"></i>

                <h2 class="text-3xl font-semibold mt-6">
                    No Orders Yet
                </h2>

                <p class="text-gray-500 mt-3">
                    Looks like you haven't placed any orders yet.
                </p>

                <a href="/shop" class="inline-block mt-8 bg-pink-400 hover:bg-pink-500 text-white px-8 py-3 rounded-xl font-semibold transition">
                    Continue Shopping
                </a>

            </div>

        <% } else { %>

            <div class="flex flex-col gap-6">

                <% orders.forEach(function(order){ %>

                    <div class="bg-white rounded-xl shadow-md p-6">

                        <div class="flex justify-between items-center">

                            <div>

                                <p class="text-gray-500 text-sm">
                                    Order ID
                                </p>

                                <h2 class="font-semibold text-lg">
                                    <%= order._id %>
                                </h2>

                                <p class="text-gray-500 mt-2">
                                    <%= order.createdAt.toDateString() %>
                                </p>

                            </div>

                            <div class="text-right">

                                <p class="text-pink-500 font-semibold text-lg">
                                    <%= order.orderStatus %>
                                </p>

                                <p class="text-2xl font-bold mt-2">
                                    ₹ <%= order.totalAmount %>
                                </p>

                            </div>

                        </div>

                        <hr class="my-5">

                        <div class="flex gap-5 overflow-x-auto">

                            <% order.items.forEach(function(item){ %>

                                <div class="flex items-center gap-4 min-w-fit">

                                    <div class="w-20 h-20 rounded-lg bg-pink-100 flex justify-center items-center">

                                        <img class="max-h-16" src="data:image/jpeg;base64,<%= item.image.toString('base64') %>">

                                    </div>

                                    <div>

                                        <h3 class="font-semibold">
                                            <%= item.name %>
                                        </h3>

                                        <p class="text-gray-500">
                                            Qty : <%= item.quantity %>
                                        </p>

                                    </div>

                                </div>

                            <% }) %>

                        </div>

                        <div class="flex justify-end mt-6">

                            <a href="/orders/<%= order._id %>" class="bg-pink-400 hover:bg-pink-500 text-white px-6 py-3 rounded-xl font-semibold transition">
                                View Details
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<%- include("./partials/footer") %>