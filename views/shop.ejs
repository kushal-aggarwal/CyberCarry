<%- include("partials/header") %>

<% if(success.length>0) { %>
    <div class="fixed top-5 left-1/2 -translate-x-1/2 -translate-y-1/2">
        <div id="flash-message" class="px-6 py-2 rounded-md bg-pink-500 shadow-lg">
            <span class="text-white text-xl"><%= success[0] %></span>
        </div>
    </div>
<% } %>

<div class="min-h-screen bg-pink-100 flex">

    <div class="w-64 bg-pink-200 shadow-lg sticky top-0 h-screen p-7 flex flex-col">
        <h2 class="text-3xl font-bold mb-6">Shop</h2>

        <div class="mb-10">
            <h3 class="font-bold text-pink-500 text-xl mb-3">Sort By</h3>

            <form action="/shop" method="GET">

                <select name="sortby" onchange="this.form.submit()" class="w-full border bg-pink-100 rounded-lg px-3 py-2">

                    <option value="" <%= !sortby ? "selected" : "" %>>
                        Default
                    </option>

                    <option value="priceDesc" <%= sortby === "priceDesc" ? "selected" : "" %>>
                        Price: High → Low
                    </option>

                    <option value="priceAsc" <%= sortby === "priceAsc" ? "selected" : "" %>>
                        Price: Low → High
                    </option>

                </select>

            </form>
        </div>

        <div class="mt-auto pt-6 border-t border-pink-300">

    <p class="text-sm text-gray-500">
        Built by
    </p>

    <h3 class="text-pink-500 text-2xl font-bold mb-10">
        CyberForge
    </h3>

</div>
    </div>

    <div class="flex-1 px-10 py-10">

        <div class="max-w-7xl mx-auto">

            <h1 class="text-5xl font-bold">Discover</h1>
            <p class="text-gray-500 mt-2 mb-10">Browse our premium collection.</p>

            <div class="grid grid-cols-4 gap-6">

                <% products.forEach(function(product){ %>

                    <div class="bg-white rounded-xl shadow-sm overflow-hidden transition duration-200 hover:-translate-y-1 hover:shadow-lg">

                        <div class="w-full h-52 bg-[<%= product.bgcolor %>] flex items-center justify-center overflow-hidden">
                            <img
                                class="max-w-[80%] max-h-[80%] object-contain transition duration-200 hover:scale-105"
                                src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                                alt="">
                        </div>

                        <div class="p-6">
                            <h3 class="text-lg font-semibold"><%= product.name %></h3>
                            <p class="text-gray-500 mt-1">Premium Bag</p>

                            <div class="flex justify-between items-center mt-6">
                                <p class="text-xl font-semibold">₹ <%= product.price %></p>

                                <a
                                    href="/addtocart/<%= product._id %>?redirect=shop"
                                    class="btn bg-pink-500 hover:bg-pink-600 text-[18px] text-white px-4 py-1 rounded-full transition">
                                    + Add
                                </a>
                            </div>
                        </div>

                    </div>

                <% }) %>

            </div>

        </div>

    </div>

</div>

<script>
    let y = sessionStorage.getItem("scrollY");

    if(y !== null) {
        window.scrollTo(0, y);
        sessionStorage.removeItem("scrollY");
    }

    let buttons = document.querySelectorAll(".btn");

    buttons.forEach(function(btn) {
        btn.addEventListener("click", function() {
            sessionStorage.setItem("scrollY", window.scrollY);
        });
    });
</script>

<%- include("partials/footer") %>