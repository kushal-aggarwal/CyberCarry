<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CyberBag</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
@keyframes shake {
    0% {
        transform: translateX(0);
    }
    20% {
        transform: translateX(-10px);
    }
    40% {
        transform: translateX(10px);
    }
    60% {
        transform: translateX(-8px);
    }
    80% {
        transform: translateX(8px);
    }
    100% {
        transform: translateX(0);
    }
}

#flash-message {
    animation: shake 0.5s ease-in-out;
}
</style>
</head>

<body>
    <% if(error.length>0) { %>
        <div class="fixed top-5 left-1/2 -translate-x-1/2 -translate-y-1/2">
            <div id="flash-message" class="p-3 rounded-md bg-red-500 shadow-lg">
                <span class="text-white"><%= error[0] %></span>
            </div>
        </div>
    <% } %>
            <div class="w-full h-screen flex px-20">
                <div class="w-1/2 flex items-center justify-center h-screen">
                    <div class="w-3/4 h-screen bg-pink-200 flex items-center">
                        <div class="px-12 w-full">
                            <h3 class="text-4xl mb-3">Welcome To <span class="text-pink-500 font-semibold">CyberBag</span></h3>
                            <h4 class="text-2xl capitalize mb-5">create your account</h4>
                            <form autocomplete="off" action="/users/register" method="post">
                                <input
                                    class="bg-pink-100 block w-full px-3 py-2 border-[1px] rounded-md mb-3 border-zinc-200"
                                    type="text" placeholder="Full Name" name="fullname">
                                <input
                                    class="bg-pink-100 block w-full px-3 py-2 border-[1px] rounded-md mb-3 border-zinc-200"
                                    type="email" placeholder="Email" name="email">
                                <input
                                    class="bg-pink-100 block w-full px-3 py-2 border-[1px] rounded-md mb-3 border-zinc-200"
                                    type="password" placeholder="Password" name="password">
                                <input class="px-5 rounded-full py-2 mt-2 bg-pink-500 text-white" type="submit"
                                    value="Create My Account">
                            </form>
                            </div>
                    </div>
                </div>
                <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-pink-500 text-white ml-5 flex items-center justify-center">OR</div>
                <div class="w-1/2 flex items-center justify-center h-screen">
                    <div class="w-full px-32">
                        <h4 class="text-2xl capitalize mb-5">login your account</h4>
                        <form autocomplete="off" action="/users/login" method="post">
                            <input
                                class="block bg-pink-100 w-full px-3 py-2 border-[1px] rounded-md mb-3 border-zinc-200"
                                type="email" placeholder="Email" name="email">
                            <input
                                class="block bg-pink-100 w-full px-3 py-2 border-[1px] rounded-md mb-3 border-zinc-200"
                                type="password" placeholder="Password" name="password">
                            <input class="px-5 block rounded-full py-2 mt-2 bg-pink-500 text-white" type="submit"
                                value="Login">
                        </form>
                    </div>
                </div>
            </div>
    <script>
        const flash = document.getElementById("flash-message");

        if (flash) {
            setTimeout(() => {
                flash.style.transition = "opacity 0.5s";
                flash.style.opacity = "0";
                setTimeout(() => flash.remove(), 500);
            }, 3000);
        }
</script>
<%- include("partials/footer") %>