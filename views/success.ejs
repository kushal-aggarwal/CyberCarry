<%- include("./partials/header") %>

<div class="min-h-screen bg-pink-100 flex justify-center items-center">

    <div class="bg-white rounded-2xl shadow-md p-10 w-[550px]">

        <div id="processing" class="text-center">

            <div class="w-16 h-16 border-4 border-pink-200 border-t-pink-500 rounded-full animate-spin mx-auto"></div>

            <h2 class="text-3xl font-semibold mt-8">
                Processing Payment...
            </h2>

            <p class="text-gray-500 mt-3">
                Please don't refresh or close this page.
            </p>

        </div>

        <div id="success" class="hidden text-center">

            <div class="w-24 h-24 rounded-full bg-green-100 flex items-center justify-center mx-auto">
                <i class="ri-check-line text-6xl text-green-600"></i>
            </div>

            <h1 class="text-4xl font-bold mt-8">
                Order Placed!
            </h1>

            <p class="text-gray-500 mt-4">
                Thank you for shopping with CyberCarry.
            </p>

            <p class="text-gray-500 mt-2">
                Your order has been placed successfully.
            </p>

            <div class="bg-pink-50 rounded-xl mt-8 p-5">

                <div class="flex justify-between">
                    <span>Payment Method</span>
                    <span class="font-semibold"><%= order.paymentMethod %></span>
                </div>

                <div class="flex justify-between mt-3">
                    <span>Order Total</span>
                    <span class="font-semibold">₹ <%= order.totalAmount %></span>
                </div>

                <div class="flex justify-between mt-3">
                    <span>Status</span>
                    <span class="text-green-600 font-semibold">
                        <%= order.orderStatus %>
                    </span>
                </div>

            </div>

            <div class="flex gap-4 mt-8">

                <a href="/shop" class="w-1/2 text-center bg-pink-400 hover:bg-pink-500 text-white py-3 rounded-xl font-semibold transition">
                    Continue Shopping
                </a>

                <a href="/orders" class="w-1/2 text-center border-2 border-pink-400 text-pink-500 hover:bg-pink-50 py-3 rounded-xl font-semibold transition">
                    View Orders
                </a>

            </div>

        </div>

    </div>

</div>

<script>

    setTimeout(function() {

        document.getElementById("processing").classList.add("hidden");
        document.getElementById("success").classList.remove("hidden");

    }, 1500);

</script>

<%- include("./partials/footer") %>